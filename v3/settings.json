{
  "workbench.settings.applyToAllProfiles": [
    "editor.tabSize"
  ],
  "chat.editor.wordWrap": "on",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "files.hotExit": "off",
  "task.quickOpen.history": 0,
  "telemetry.feedback.enabled": false,
  "editor.fontFamily": "Consolas",
  "editor.tabSize": 2,
  "editor.rulers": [120],
  "editor.folding": true,
  "editor.cursorWidth": 2,
  "editor.lineHeight": 1.6,
  "editor.lineNumbers": "on",
  "editor.glyphMargin": true,
  "editor.fontLigatures": true,
  "editor.wordWrapColumn": 120,
  "editor.mouseWheelZoom": false,
  "editor.smoothScrolling": true,
  "editor.cursorBlinking": "smooth",
  "editor.wordWrap": "wordWrapColumn",
  "editor.inlineSuggest.enabled": false,
  "editor.tokenColorCustomizations": {},
  "editor.suggestOnTriggerCharacters": false,
  "editor.language.colorizedBracketPairs": [],
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.stickyScroll.maxLineCount": 3,
  "git.confirmSync": false,
  "git.decorations.enabled": true,
  "git.autoRepositoryDetection": false,
  "git.openRepositoryInParentFolders": "never",
  "github.copilot.renameSuggestions.triggerAutomatically": false,
  "python.createEnvironment.trigger": "off",
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.confirmOnExit": "always",
  "terminal.integrated.defaultLocation": "editor",
  "terminal.integrated.cursorStyleInactive": "none",
  "workbench.editor.highlightModifiedTabs": true,
  "window.restoreWindows": "none",
  "window.title": "${dirty}${folderName}${separator}${activeEditorShort} - VSCode",
  "workbench.colorCustomizations": {
    "editor.background": "#162335",
    "editor.selectionBackground":"#7177b889",
    "editorRuler.foreground":"#383c6a",
    "editor.wordHighlightBackground":"#7177b88d",
    "editor.lineHighlightBorder":"#283e5c",
    "editor.lineHighlightBackground":"#546bc01c",
    "editorLineNumber.foreground":"#5b6097",
    "editorIndentGuide.background1":"#3a3f6c",
    "editorIndentGuide.activeBackground1":"#5b6097",
    "editorStickyScrollHover.background":"#546bc01c",
    "list.inactiveSelectionBackground":"#2c3b61",
    "list.hoverBackground":"#2c3b61",
    "sideBar.background":"#1d2947",
    "sideBar.border":"#1d2947",
    "activityBar.background":"#1d2947",
    "titleBar.activeBackground":"#1d2947",
    "tab.activeBackground":"#162335",
    "tab.inactiveBackground":"#1d2947",
    "tab.inactiveForeground":"#7177b8",
    "tab.border":"#272b53",
    "editorGroupHeader.tabsBackground":"#1d2947",
    "menu.background":"#1d2c51",
    "menu.border":"#1d2947",
    "menu.separatorBackground":"#3f437f",
    "menu.foreground":"#babee6",
    "statusBar.background":"#1d2947",
    "scrollbar.shadow":"#272b53",
    "scrollbarSlider.background":"#3f437f",
    "input.background":"#343871",
    "dropdown.background":"#343871"
  },
  "window.zoomPerWindow": false,
  "workbench.reduceMotion": "on",
  "workbench.list.scrollByPage": true,
  "workbench.commandPalette.history": 10,
  "workbench.editor.scrollToSwitchTabs": true,
  "workbench.tree.stickyScrollMaxItemCount": 3,
  "workbench.editor.tabSizingFixedMinWidth": 80,
  "workbench.editor.tabSizingFixedMaxWidth": 120,
  "workbench.colorTheme": "Default Dark+",
  "workbench.editor.focusRecentEditorAfterClose": false,
  "workbench.editor.historyBasedLanguageDetection": false,
  "search.quickOpen.includeHistory": false,
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/env": true,
    "**/venv": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/env/**": true,
    "**/venv/**": true,
    "env-*": true
  }
}